# ─── Lab Manager — Configuration ───────────────────────────
# Copier ce fichier en .env et adapter les valeurs

# IP ou hostname du VPS (ce que l'apprenant voit dans son navigateur)
BASE_HOST=localhost

# Port d'écoute de l'API Lab Manager
API_PORT=4000

# Clé secrète partagée avec le site d'apprentissage
# L'autre dev doit mettre cette même valeur dans son .env
API_SECRET=change_me_in_production_use_long_random_string

# Durée de vie d'un conteneur en secondes (45 min par défaut)
LAB_TTL=2700

# Chemin vers le dossier qui contient les labs (avec leurs docker-compose.yml)
LABS_DIR=/opt/labs

# Réseau Docker partagé entre tous les conteneurs labs
DOCKER_NETWORK=lab-network
